---
/* ── Sobre mí Page (/sobre-mi) ── */
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";
import TechBadge from "../components/ui/TechBadge.astro";
import BackgroundBeamsWithCollision from "../components/BackgroundBeamsWithCollision";
import SkyBanner from "../components/SkyBanner";
import { site } from "../data/site";
import { skillCategories } from "../data/skills";
import { withBasePath } from "../utils/base-path";

const iconWhatWeb =
    '<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="M4 20q-.825 0-1.412-.587T2 18V6q0-.825.588-1.412T4 4h16q.825 0 1.413.588T22 6v12q0 .825-.587 1.413T20 20zm0-2h10.5v-3.5H4zm12.5 0H20V9h-3.5zM4 12.5h10.5V9H4z"/></svg>';
const iconWhatSupabase =
    '<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 128 128"><path fill="currentColor" fill-opacity=".9" d="M102.24 186.21c-3.267 4.117-9.904 1.862-9.977-3.397l-1.156-76.906h51.715c9.365 0 14.587 10.817 8.763 18.149z" transform="translate(-27.722 -60.338)"/><path fill="currentColor" fill-opacity=".2" d="M102.24 186.21c-3.267 4.117-9.904 1.862-9.977-3.397l-1.156-76.906h51.715c9.365 0 14.587 10.817 8.763 18.149z" transform="translate(-27.722 -60.338)"/><path fill="currentColor" d="M53.484 2.128c3.267-4.117 9.905-1.862 9.977 3.396l.508 76.907H12.902c-9.365 0-14.587-10.817-8.764-18.149z"/></svg>';
const iconWhatAutomation =
    '<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V2H8m7 9v2M2 12h2m16 0h2m-2 4a2 2 0 0 1-2 2H8.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 4 20.286V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2zM9 11v2"/></svg>';
const iconWhatTalk =
    '<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 0 1-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>';
const iconWhatDesktop =
    '<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 512 512"><path fill="currentColor" d="M16 352a48.05 48.05 0 0 0 48 48h133.88l-4 32H144a16 16 0 0 0 0 32h224a16 16 0 0 0 0-32h-49.88l-4-32H448a48.05 48.05 0 0 0 48-48v-48H16Zm240-16a16 16 0 1 1-16 16a16 16 0 0 1 16-16M496 96a48.05 48.05 0 0 0-48-48H64a48.05 48.05 0 0 0-48 48v192h480Z"/></svg>';
const iconWhatCloud =
    '<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="M6.5 20q-2.275 0-3.887-1.575T1 14.575q0-1.95 1.175-3.475T5.25 9.15q.625-2.3 2.5-3.725T12 4q2.925 0 4.963 2.038T19 11q1.725.2 2.863 1.488T23 15.5q0 1.875-1.312 3.188T18.5 20z"/></svg>';
const iconWhatCommerce =
    '<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="M17 18c-1.11 0-2 .89-2 2a2 2 0 0 0 2 2a2 2 0 0 0 2-2a2 2 0 0 0-2-2M1 2v2h2l3.6 7.59l-1.36 2.45c-.15.28-.24.61-.24.96a2 2 0 0 0 2 2h12v-2H7.42a.25.25 0 0 1-.25-.25q0-.075.03-.12L8.1 13h7.45c.75 0 1.41-.42 1.75-1.03l3.58-6.47c.07-.16.12-.33.12-.5a1 1 0 0 0-1-1H5.21l-.94-2M7 18c-1.11 0-2 .89-2 2a2 2 0 0 0 2 2a2 2 0 0 0 2-2a2 2 0 0 0-2-2"/></svg>';
const iconWhatArchitecture =
    '<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="M4 21v-2q0-.825.588-1.412T6 17h.5v-2H6q-.825 0-1.412-.587T4 13v-2q0-.825.588-1.412T6 9h.5V7H6q-.825 0-1.412-.587T4 5V3q0-.825.588-1.412T6 1h3q.825 0 1.413.588T11 3v2q0 .825-.587 1.413T9 7h-.5v2H9q.825 0 1.413.588T11 11h3q0-.825.588-1.412T16 9h3q.825 0 1.413.588T21 11v2q0 .825-.587 1.413T19 15h-3q-.825 0-1.412-.587T14 13h-3q0 .825-.587 1.413T9 15h-.5v2H9q.825 0 1.413.588T11 19v2q0 .825-.587 1.413T9 23H6q-.825 0-1.412-.587T4 21m2 0h3v-2H6zm0-8h3v-2H6zm10 0h3v-2h-3zM6 5h3V3H6zm1.5 15"/></svg>';
---

<BaseLayout
    title="Sobre mí — Rubén Pezuela García"
    description="Full Stack Developer y CTO de iCreate Group. Construyo CRMs propios, automatizo procesos con n8n y desarrollo productos digitales de alto rendimiento desde cero hasta producción."
>
    <!-- ═══ HERO HEADER ═══ -->
    <section
        class="pt-16 sm:pt-24 min-h-[calc(100svh-10rem)] relative overflow-hidden flex flex-col"
    >
        <div class="absolute inset-0 z-0">
            <SkyBanner
                client:load
                sunSrc={withBasePath("/images/sol.png")}
                cloudsSrc={withBasePath("/images/nubes.png")}
                height="clamp(320px, 62vw, 720px)"
                ariaLabel="Background banner"
                className="h-full w-full rounded-none!"
            />
        </div>
        <div
            class="absolute inset-0 z-1 pointer-events-none bg-linear-to-r from-bg-primary/95 via-bg-primary/72 to-bg-primary/45"
        >
        </div>
        <div
            class="absolute inset-0 z-1 pointer-events-none bg-linear-to-t from-bg-primary/60 via-transparent to-transparent"
        >
        </div>

        <!-- Background decoration -->
        <div
            class="absolute inset-0 z-1 bg-[radial-gradient(ellipse_at_top_left,rgba(59,130,246,0.12),transparent_60%)] pointer-events-none"
        >
        </div>
        <div
            class="absolute inset-0 z-1 bg-[radial-gradient(ellipse_at_bottom_right,rgba(255,255,0,0.05),transparent_60%)] pointer-events-none"
        >
        </div>

        <div
            class="relative z-10 overflow-hidden bg-bg-primary/10 shadow-[0_20px_80px_rgba(15,23,42,0.35)] animate-fade-in"
        >
            <Container size="lg" class="relative z-10">
                <div
                    class="relative z-10 flex min-h-100 flex-col items-start gap-6 py-6 sm:min-h-112 sm:flex-row sm:gap-10 sm:py-10 lg:min-h-120 lg:py-12"
                >
                    <!-- Photo -->
                    <div class="shrink-0 mx-auto sm:mx-0">
                        <div class="relative">
                            <div
                                class="absolute -inset-3 rounded-2xl bg-linear-to-br from-secondary/30 to-accent/10 blur-xl opacity-60"
                            >
                            </div>
                            <div
                                class="w-36 h-36 sm:w-44 sm:h-44 rounded-2xl overflow-hidden border border-secondary/30 shadow-[0_0_40px_rgba(59,130,246,0.2)] relative"
                            >
                                <img
                                    src={withBasePath("/FotoPerfil.png")}
                                    alt={`Foto de ${site.name}`}
                                    class="w-full h-full object-cover"
                                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                                />
                                <div
                                    class="absolute inset-0 bg-bg-tertiary items-center justify-center hidden"
                                    aria-hidden="true"
                                >
                                    <svg
                                        class="w-16 h-16 text-text-dim"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="1.5"
                                            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                                        ></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Intro -->
                    <div
                        class="max-w-xl w-full rounded-[1.4rem] border border-white/10 bg-[linear-gradient(160deg,rgba(5,10,18,0.58),rgba(5,10,18,0.22))] p-4 backdrop-blur-sm sm:rounded-none sm:border-0 sm:bg-transparent sm:p-0 sm:backdrop-blur-none"
                    >
                        <div class="flex flex-wrap gap-1.5 mb-3 sm:mb-4">
                            <Badge variant="accent" size="md"
                                >Cofounder & CTO</Badge
                            >
                            <Badge variant="neutral" size="md"
                                >iCreate Group</Badge
                            >
                            <Badge variant="neutral" size="md"
                                >Full Stack Dev</Badge
                            >
                        </div>
                        <h1
                            class="text-2xl sm:text-5xl font-black text-white mb-2 sm:mb-3 leading-tight"
                        >
                            {site.name}
                        </h1>
                        <p
                            class="text-secondary font-semibold text-sm sm:text-lg mb-3 sm:mb-4 tracking-[0.08em] uppercase sm:tracking-normal sm:normal-case"
                        >
                            Full Stack Developer · CRM · Automatización · Cloud
                        </p>
                        <p
                            class="text-white/85 text-sm sm:text-base leading-relaxed max-w-lg"
                        >
                            Construyo productos digitales <strong
                                class="text-white">de principio a fin</strong
                            >, sin intermediarios. Del diseño técnico al deploy
                            en producción.
                        </p>

                        <div
                            class="mt-5 flex flex-col gap-2.5 sm:mt-6 sm:flex-row sm:flex-wrap sm:gap-3"
                        >
                            <Button
                                href="/contacto"
                                variant="primary"
                                size="md"
                                class="w-full sm:w-auto"
                            >
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                    ></path>
                                </svg>
                                Contactar
                            </Button>
                            <Button
                                href="/cv/CV%20%E2%80%94%20Rub%C3%A9n%20Pezuela%20Garc%C3%ADa.pdf"
                                variant="outline"
                                size="md"
                                class="w-full sm:w-auto"
                                external
                            >
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                    ></path>
                                </svg>
                                Descargar CV
                            </Button>
                        </div>
                    </div>
                </div>
            </Container>
        </div>

        <div class="relative z-10 mt-auto">
            <div
                class="absolute inset-0 pointer-events-none bg-linear-to-b from-bg-primary/12 via-bg-primary/52 to-bg-primary/82"
            >
            </div>
            <div
                class="absolute inset-0 pointer-events-none bg-[radial-gradient(ellipse_at_top,rgba(59,130,246,0.08),transparent_60%)]"
            >
            </div>
            <Container size="md" class="relative z-10 py-8 sm:py-10">
                <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
                    {
                        [
                            { value: "2025", label: "Desde" },
                            { value: "3+", label: "Productos vivos" },
                            { value: "100%", label: "Full ownership" },
                            { value: "iCreate", label: "Group CTO" },
                        ].map((stat) => (
                            <div>
                                <div class="text-3xl font-black text-accent mb-1">
                                    {stat.value}
                                </div>
                                <div class="text-xs text-text-muted uppercase tracking-widest">
                                    {stat.label}
                                </div>
                            </div>
                        ))
                    }
                </div>
            </Container>
        </div>
    </section>

    <div class="relative isolate overflow-hidden">
        <BackgroundBeamsWithCollision
            client:load
            className="absolute inset-0 h-full w-full opacity-90"
        />

        <div class="relative z-10">
            <section class="py-16 sm:py-20">
                <Container size="md">
                    <!-- ── Quién soy ── -->
                    <div
                        class="motion-surface space-y-5 mb-16 bg-ui-surface p-8 rounded-2xl border border-ui-border relative overflow-hidden"
                        data-motion-active="false"
                    >
                        <div
                            class="absolute top-0 left-0 w-1 h-full bg-accent rounded-l-2xl"
                        >
                        </div>
                        <h2
                            class="text-xl font-black text-text-primary flex items-center gap-3"
                        >
                            <span class="text-accent">01</span>
                            Quién soy
                        </h2>
                        <div
                            class="text-text-secondary leading-relaxed text-base"
                        >
                            <div class="hidden sm:block space-y-4">
                                <p>
                                    Soy <strong class="text-text-primary"
                                        >Rubén Pezuela García</strong
                                    >, Full Stack Developer con obsesión por la
                                    automatización y los productos que funcionan
                                    en producción. Actualmente soy <strong
                                        class="text-text-primary"
                                        >Cofounder y CTO de iCreate Group</strong
                                    >, donde diseño e implemento la
                                    infraestructura técnica completa — sin un
                                    equipo de 20 personas, sin procesos lentos,
                                    solo código limpio y soluciones que escalan.
                                </p>
                                <p>
                                    Mi especialidad está en el cruce entre <strong
                                        class="text-text-primary"
                                        >producto, código y negocio</strong
                                    >: entiendo qué necesita el negocio, lo
                                    traduzco a arquitectura técnica y lo
                                    ejecuto. Desde CRM iLead (lead-to-cash),
                                    hasta plataformas de automatización con n8n,
                                    e-commerces headless y apps desktop con
                                    Kotlin.
                                </p>
                                <p>
                                    No me interesa el código por el código. Me
                                    interesa el <strong
                                        class="text-text-primary"
                                        >impacto real</strong
                                    >: tiempo ahorrado, procesos automatizados,
                                    productos que los usuarios aman usar.
                                </p>
                            </div>

                            <div class="space-y-4 sm:hidden">
                                <p>
                                    Soy <strong class="text-text-primary"
                                        >Rubén Pezuela García</strong
                                    >, Full Stack Developer con obsesión por la
                                    automatización y los productos que funcionan
                                    en producción. Actualmente soy <strong
                                        class="text-text-primary"
                                        >Cofounder y CTO de iCreate Group</strong
                                    >, donde diseño e implemento la
                                    infraestructura técnica completa — sin un
                                    equipo de 20 personas, sin procesos lentos,
                                    solo código limpio y soluciones que escalan.
                                </p>

                                <details
                                    class="group rounded-xl border border-ui-border bg-bg-secondary/40"
                                >
                                    <summary
                                        class="cursor-pointer list-none px-4 py-3 text-sm font-semibold text-accent [&::-webkit-details-marker]:hidden"
                                    >
                                        <span class="group-open:hidden"
                                            >...más</span
                                        >
                                        <span class="hidden group-open:inline"
                                            >mostrar menos</span
                                        >
                                    </summary>

                                    <div class="space-y-4 px-4 pb-4">
                                        <p>
                                            Mi especialidad está en el cruce
                                            entre <strong
                                                class="text-text-primary"
                                                >producto, código y negocio</strong
                                            >: entiendo qué necesita el negocio,
                                            lo traduzco a arquitectura técnica y
                                            lo ejecuto. Desde CRM iLead
                                            (lead-to-cash), hasta plataformas de
                                            automatización con n8n, e-commerces
                                            headless y apps desktop con Kotlin.
                                        </p>
                                        <p>
                                            No me interesa el código por el
                                            código. Me interesa el <strong
                                                class="text-text-primary"
                                                >impacto real</strong
                                            >: tiempo ahorrado, procesos
                                            automatizados, productos que los
                                            usuarios aman usar.
                                        </p>
                                    </div>
                                </details>
                            </div>
                        </div>
                    </div>

                    <!-- ── Lo que hago ── -->
                    <div class="space-y-6 mb-16">
                        <h2
                            class="text-xl font-black text-text-primary flex items-center gap-3"
                        >
                            <span class="text-accent">02</span>
                            Lo que hago
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                            {
                                [
                                    {
                                        icon: iconWhatWeb,
                                        text: "Webs y apps con Astro, Tailwind CSS, React y TypeScript",
                                        iconClass:
                                            "border-secondary/30 bg-secondary/10 text-secondary",
                                    },
                                    {
                                        icon: iconWhatSupabase,
                                        text: "Backends y APIs con Supabase/PostgreSQL y Firebase",
                                        iconClass:
                                            "border-secondary/30 bg-secondary/10 text-secondary",
                                    },
                                    {
                                        icon: iconWhatAutomation,
                                        text: "Automatización de procesos empresariales con n8n y webhooks",
                                        iconClass:
                                            "border-accent/25 bg-accent/10 text-accent",
                                    },
                                    {
                                        icon: iconWhatTalk,
                                        text: "Chatbots y asistentes IA para lead generation y soporte",
                                        iconClass:
                                            "border-accent/25 bg-accent/10 text-accent",
                                    },
                                    {
                                        icon: iconWhatDesktop,
                                        text: "Apps desktop con Java, Kotlin, Compose Multiplatform",
                                        iconClass:
                                            "border-secondary/30 bg-secondary/10 text-secondary",
                                    },
                                    {
                                        icon: iconWhatCloud,
                                        text: "Infraestructura con Docker, Traefik, DigitalOcean y VPS",
                                        iconClass:
                                            "border-secondary/30 bg-secondary/10 text-secondary",
                                    },
                                    {
                                        icon: iconWhatCommerce,
                                        text: "E-commerce headless con WooCommerce API",
                                        iconClass:
                                            "border-accent/25 bg-accent/10 text-accent",
                                    },
                                    {
                                        icon: iconWhatArchitecture,
                                        text: "Arquitecturas multi-tenant escalables",
                                        iconClass:
                                            "border-accent/25 bg-accent/10 text-accent",
                                    },
                                ].map((item) => (
                                    <div
                                        class="motion-surface flex items-start gap-3 bg-bg-secondary border border-ui-border rounded-xl p-4 hover:border-secondary/30 transition-colors"
                                        data-motion-active="false"
                                    >
                                        <span
                                            class={`flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border mt-0.5 leading-none [&>svg]:block [&>svg]:h-4.5 [&>svg]:w-4.5 ${item.iconClass}`}
                                            set:html={item.icon}
                                        />
                                        <span class="text-text-secondary text-sm leading-relaxed">
                                            {item.text}
                                        </span>
                                    </div>
                                ))
                            }
                        </div>
                    </div>

                    <!-- ── Stack principal ── -->
                    <div class="space-y-6 mb-16">
                        <h2
                            class="text-xl font-black text-text-primary flex items-center gap-3"
                        >
                            <span class="text-accent">03</span>
                            Stack en producción
                        </h2>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            {
                                skillCategories.map((cat) => (
                                    <div
                                        class="motion-surface bg-bg-secondary border border-ui-border rounded-2xl p-5 hover:border-secondary/30 transition-all duration-300"
                                        data-motion-active="false"
                                    >
                                        <h3 class="text-sm font-bold text-text-primary mb-3 flex items-center gap-2">
                                            <span
                                                class="text-2xl"
                                                set:html={cat.icon}
                                            />
                                            {cat.title}
                                        </h3>
                                        <div class="flex flex-wrap gap-1.5">
                                            {cat.skills.map((skill) => (
                                                <TechBadge
                                                    label={skill.name}
                                                    variant="neutral"
                                                    size="sm"
                                                />
                                            ))}
                                        </div>
                                    </div>
                                ))
                            }
                        </div>
                    </div>

                    <!-- ── Ahora mismo ── -->
                    <div class="space-y-5 mb-16">
                        <h2
                            class="text-xl font-black text-text-primary flex items-center gap-3"
                        >
                            <span class="text-accent">04</span>
                            Ahora mismo enfocado en…
                        </h2>
                        <div
                            class="motion-surface bg-secondary/8 border border-secondary/25 rounded-2xl p-6 relative overflow-hidden"
                            data-motion-active="false"
                        >
                            <div
                                class="absolute top-4 right-4 w-2 h-2 bg-accent rounded-full animate-pulse"
                            >
                            </div>
                            <p class="text-text-secondary leading-relaxed">
                                <strong class="text-secondary"
                                    >Agente de voz IA para llamadas</strong
                                > — Sistema que atiende llamadas entrantes, conversa
                                por voz y agenda citas de forma completamente automática.
                                Integrado con <strong class="text-text-primary"
                                    >Supabase</strong
                                > como capa de persistencia y <strong
                                    class="text-text-primary"
                                    >Docker + Traefik</strong
                                > en DigitalOcean. El objetivo: zero human intervention
                                en el proceso de cualificación y agendado.
                            </p>
                        </div>
                    </div>

                    <!-- ── Experiencia ── -->
                    <div class="space-y-6">
                        <h2
                            class="text-xl font-black text-text-primary flex items-center gap-3"
                        >
                            <span class="text-accent">05</span>
                            Experiencia
                        </h2>
                        <div class="relative">
                            <div
                                class="absolute left-5 top-0 bottom-0 w-px bg-ui-border"
                            >
                            </div>
                            <div class="relative pl-14">
                                <div
                                    class="absolute left-3.5 top-1 w-3.5 h-3.5 bg-secondary rounded-full border-2 border-bg-primary shadow-[0_0_12px_rgba(59,130,246,0.5)]"
                                >
                                </div>
                                <div
                                    class="motion-surface bg-bg-secondary border border-ui-border rounded-2xl p-6"
                                    data-motion-active="false"
                                >
                                    <div
                                        class="flex flex-wrap items-start justify-between gap-3 mb-3"
                                    >
                                        <div>
                                            <h3
