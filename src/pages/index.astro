					data-motion-active="false"
				>
					<div
						class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,rgba(59,130,246,0.16),transparent_58%)] pointer-events-none"
					>
					</div>
					<div
						class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(255,255,0,0.08),transparent_52%)] pointer-events-none"
					>
					</div>
					<div
						class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.03),transparent_32%,rgba(10,10,10,0.12)_100%)] pointer-events-none"
					>
					</div>
					<div
						class="absolute left-10 top-8 h-40 w-40 rounded-full bg-secondary/14 blur-3xl pointer-events-none"
					>
					</div>
					<div
						class="absolute right-10 top-1/2 h-28 w-28 -translate-y-1/2 rounded-full bg-secondary/8 blur-3xl pointer-events-none"
					>
					</div>
					<div
						class="absolute -bottom-12 right-12 h-36 w-36 rounded-full bg-accent/10 blur-3xl pointer-events-none"
					>
					</div>
					<div
						class="absolute inset-x-10 top-0 h-px bg-linear-to-r from-transparent via-secondary/40 to-transparent pointer-events-none"
					>
					</div>

					<div class="relative z-10">
						<span
							class="inline-block text-accent text-sm font-semibold uppercase tracking-widest mb-4"
							>¿Tienes un proyecto?</span
						>
						<h2
							class="text-3xl sm:text-4xl font-black text-text-primary mb-4 leading-tight"
						>
							Construyamos algo<br /><span
								class="text-transparent bg-clip-text bg-linear-to-r from-accent to-secondary/80"
								>que funcione de verdad</span
							>
						</h2>
						<p
							class="text-text-secondary text-lg mb-8 max-w-lg mx-auto leading-relaxed"
						>
							Sin agencias intermediarias. Hablo directamente
							contigo, entiendo tu negocio y entrego código que
							funciona.
						</p>
						<div
							class="flex flex-col sm:flex-row items-center justify-center gap-4"
						>
							<Button
								href={withBasePath("/contacto")}
								variant="primary"
								size="lg"
							>
								<svg
									class="w-5 h-5"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
									></path>
								</svg>
								Contactar ahora
							</Button>
							<Button
								href={withBasePath("/sobre-mi")}
								variant="ghost"
								size="lg"
							>
								Conocerme mejor →
							</Button>
						</div>
					</div>
				</div>
			</Container>
		</section>

		<ProjectTechLogoLoop
			client:visible
			items={projectTechLogos}
			ariaLabel="Tecnologias usadas en proyectos reales"
		/>
	</div>
</BaseLayout>
