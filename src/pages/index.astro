---
/* ── Index Page (/) ── */
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";
import TechBadge from "../components/ui/TechBadge.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import ProjectCard from "../components/projects/ProjectCard.astro";
import ValuePropsBand from "../components/home/ValuePropsBand";
import ProjectTechLogoLoop from "../components/home/ProjectTechLogoLoop";
import Prism from "../components/Prism";
import { site } from "../data/site";
import { getFeaturedProjects } from "../data/projects";
import { getProjectTechLogos } from "../data/project-tech-logos";
import { skillCategories } from "../data/skills";
import { withBasePath } from "../utils/base-path";

const featuredProjects = getFeaturedProjects();
const projectTechLogos = getProjectTechLogos();

const iconBolt =
	'<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="#3b82f6" fill-rule="evenodd" d="M14 2a1 1 0 0 0-1.864-.504l-7 12A1 1 0 0 0 6 15h4v7a1 1 0 0 0 1.864.504l7-12A1 1 0 0 0 18 9h-4z" clip-rule="evenodd"/></svg>';
const iconBot =
	'<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="none" stroke="#3b82f6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V2H8m7 9v2M2 12h2m16 0h2m-2 4a2 2 0 0 1-2 2H8.828a2 2 0 0 0-1.414.586l-2.202 2.202A.71.71 0 0 1 4 20.286V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2zM9 11v2"/></svg>';
const iconRocket =
	'<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="#3b82f6" d="m2.45 10.575l4.2-4.2q.35-.35.825-.5t.975-.05l1.3.275Q8.4 7.7 7.625 9t-1.5 3.15zm5.125 2.275q.575-1.8 1.563-3.4t2.387-3q2.2-2.2 5.025-3.287t5.275-.663q.425 2.45-.65 5.275T17.9 12.8q-1.375 1.375-3 2.388t-3.425 1.587zm8.313-2.425q.837 0 1.412-.575t.575-1.412t-.575-1.413t-1.412-.575t-1.413.575t-.575 1.413t.575 1.412t1.413.575m-2.113 11.45l-1.6-3.675q1.85-.725 3.163-1.5t2.912-2.125l.25 1.3q.1.5-.05.988t-.5.837zM4.05 16.05q.875-.875 2.125-.888t2.125.863t.875 2.125t-.875 2.125q-.625.625-2.088 1.075t-4.037.8q.35-2.575.8-4.025T4.05 16.05"/></svg>';
const iconTarget =
	'<svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 36 36"><path fill="#EDEDED" d="M18 2a16 16 0 0 0-4.25.59l.77 1.86a14.07 14.07 0 1 1-10 10l-1.86-.78A16 16 0 1 0 18 2"/><path fill="#EDEDED" d="M7.45 15.7a10.81 10.81 0 1 0 8.3-8.26L16.37 9A9.24 9.24 0 1 1 9 16.32Z"/><path fill="#EDEDED" d="M18 22.09a4.08 4.08 0 0 1-4-3.68l-1.63-.68V18A5.69 5.69 0 1 0 18 12.31h-.24l.67 1.69a4.07 4.07 0 0 1-.43 8.09"/><path fill="#EDEDED" d="M8.2 13.34a.5.5 0 0 0 .35.15h3.65l5.37 5.37A1 1 0 0 0 19 17.44L13.53 12V8.51a.5.5 0 0 0-.15-.35L7.79 2.57a.5.5 0 0 0-.85.35v4H3a.5.5 0 0 0-.35.85Z"/><path fill="none" d="M0 0h36v36H0z"/></svg>';

const valueProps = [
	{
		icon: iconBolt,
		text: "Código limpio y arquitecturas escalables",
	},
	{
		icon: iconBot,
		text: "Automatización real con n8n y webhooks",
	},
	{
		icon: iconRocket,
		text: "De idea a producción sin intermediarios",
	},
	{
		icon: iconTarget,
		text: "Full ownership: diseño, desarrollo y deploy",
	},
];

const heroStats = [
	{ value: "3+", label: "Productos en producción" },
	{ value: "100%", label: "Ownership técnico" },
	{ value: "n8n", label: "Automatización avanzada" },
];
---

<BaseLayout
	title="Rubén Pezuela García — Full Stack Developer & CTO"
	description="Full Stack Developer y CTO de iCreate Group. Especializado en CRM, automatización con n8n, Astro, Kotlin y arquitecturas cloud. Construyo productos que escalan."
>
	<!-- ═══ HERO ═══ -->
	<!-- -mt-16 cancels the pt-16 on <main> so the hero starts truly at top:0 and sticky works immediately -->
	<section
		class="relative -mt-16 flex min-h-svh w-full items-start overflow-hidden z-0 lg:sticky lg:top-0 lg:h-screen lg:items-center"
		id="hero"
	>
		<!-- Prism background -->
		<div
			class="absolute inset-0 w-full h-full pointer-events-none"
			aria-hidden="true"
		>
			<div
				class="absolute inset-0"
				style="width:100%;height:100%;position:relative;"
			>
				<Prism
					height={2.5}
					baseWidth={3.5}
					animationType="rotate"
					glow={1}
					noise={0.9}
					transparent={true}
					scale={3.6}
					hueShift={0}
					colorFrequency={0.1}
					hoverStrength={1}
					inertia={0.1}
					bloom={1}
					timeScale={0.4}
					tintColor="#3b82f6"
					tintStrength={0.95}
					client:load
				/>
			</div>
			<!-- Gradientes para legibilidad -->
			<div
				class="absolute inset-0 bg-linear-to-r from-bg-primary/60 via-bg-primary/20 to-bg-primary/40"
			>
			</div>
			<div
				class="absolute inset-0 bg-[radial-gradient(circle_at_50%_45%,rgba(13,27,42,0.0)_15%,rgba(13,27,42,0.4)_65%,rgba(10,10,10,0.85)_100%)]"
			>
			</div>
			<!-- Bottom fade to next section -->
			<div
				class="absolute bottom-0 left-0 right-0 h-32 bg-linear-to-t from-bg-primary to-transparent"
			>
			</div>
		</div>

		<Container size="xl" class="relative z-10">
			<div
				class="grid min-h-svh items-center gap-10 pb-16 pt-28 sm:pb-20 sm:pt-32 lg:hidden"
			>
				<div
					class="mx-auto flex w-full max-w-2xl flex-col items-center text-center lg:mx-0 lg:items-start lg:text-left"
				>
					<div
						class="mb-6 inline-flex items-center gap-3 rounded-full border border-white/10 bg-[rgba(6,10,18,0.82)] px-3 py-2 backdrop-blur-xl lg:hidden"
					>
						<div
							class="h-11 w-11 overflow-hidden rounded-full border border-secondary/35 bg-bg-tertiary"
						>
							<img
								src={withBasePath("/FotoPerfil.png")}
								alt={`Foto de ${site.name}`}
								class="h-full w-full object-cover"
							/>
						</div>
						<div class="text-left">
							<p class="text-sm font-bold text-text-primary">
								Rubén<span class="text-accent">PG</span>
							</p>
							<p
								class="text-[0.62rem] uppercase tracking-[0.24em] text-text-muted"
							>
								Full Stack + CTO
							</p>
						</div>
					</div>

					<div
						class="w-full rounded-4xl border border-white/10 bg-[linear-gradient(180deg,rgba(6,10,18,0.82),rgba(4,7,12,0.54))] px-5 py-6 shadow-[0_28px_70px_rgba(0,0,0,0.24)] backdrop-blur-xl sm:px-7 sm:py-8 lg:border-none lg:bg-transparent lg:p-0 lg:shadow-none lg:backdrop-blur-none"
					>
						<div
							class="motion-chip inline-flex items-center gap-2 bg-secondary/10 border border-secondary/25 rounded-full px-4 py-1.5 mb-5"
							data-motion-active="false"
						>
							<span
								class="w-2 h-2 bg-accent rounded-full animate-pulse"
							></span>
							<span
								class="text-accent font-semibold text-xs uppercase tracking-widest"
								>Disponible para proyectos</span
							>
						</div>

						<p
							class="mb-4 text-[0.7rem] font-semibold uppercase tracking-[0.32em] text-secondary/70"
						>
							Full ownership técnico
						</p>

						<h1
							class="text-[clamp(3rem,15vw,5.25rem)] font-black text-secondary leading-[0.96] tracking-[-0.05em]"
						>
							<span class="block">Full Stack</span>
							<span
								class="block text-transparent bg-clip-text bg-linear-to-r from-secondary via-secondary-hover to-secondary/80"
								>Developer</span
							>
							<span
								class="mt-3 block text-[clamp(1.7rem,8vw,3rem)] font-bold leading-[1.05] tracking-[-0.04em] text-secondary/85"
								>& CTO de iCreate Group</span
							>
						</h1>

						<p
							class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-text-secondary sm:text-lg lg:mx-0 lg:text-xl"
						>
							Construyo productos que <strong
								class="text-text-primary">escalan</strong
							>. CRM a medida, automatizaciones inteligentes con
							n8n, apps desktop y webs de alto rendimiento.
						</p>

						<div
							class="mt-6 grid grid-cols-3 gap-2.5 sm:gap-3 lg:max-w-2xl"
						>
							{
								heroStats.map((stat) => (
									<div class="min-w-0 rounded-[1.25rem] border border-white/10 bg-black/25 px-2.5 py-3 text-center shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] sm:px-3 lg:text-left">
										<div class="text-xl font-black text-accent sm:text-2xl">
											{stat.value}
										</div>
										<div class="mt-1 wrap-break-word text-[0.56rem] leading-tight uppercase tracking-[0.08em] text-text-muted sm:text-[0.68rem] sm:tracking-[0.16em]">
											{stat.label}
										</div>
									</div>
								))
							}
						</div>

						<div
							class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center lg:justify-start"
						>
							<Button
								href={withBasePath("/proyectos")}
								variant="primary"
								size="lg"
								class="w-full sm:w-auto"
							>
								Ver proyectos
								<svg
									class="w-5 h-5"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
								</svg>
							</Button>
							<Button
								href={withBasePath("/contacto")}
								variant="outline"
								size="lg"
								class="w-full sm:w-auto"
							>
								Hablemos
								<svg
									class="w-5 h-5"
									fill="none"
									stroke="currentColor"
									viewBox="0 0 24 24"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										stroke-width="2"
										d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
									></path>
								</svg>
							</Button>
						</div>
					</div>
				</div>

				<div class="relative hidden lg:flex lg:justify-end">
					<div
						class="absolute inset-x-10 top-10 h-40 rounded-full bg-secondary/18 blur-3xl"
					>
					</div>
					<div class="relative">
						<div
							class="absolute -inset-6 rounded-[2.5rem] bg-[radial-gradient(circle,rgba(59,130,246,0.28),transparent_62%)] blur-3xl opacity-80"
						>
						</div>
						<div
							class="relative rounded-[2.4rem] border border-white/10 bg-[linear-gradient(180deg,rgba(6,10,18,0.86),rgba(3,6,10,0.72))] p-4 shadow-[0_32px_90px_rgba(0,0,0,0.34)] backdrop-blur-xl"
						>
							<div
								class="mb-4 flex items-center justify-between gap-4 rounded-full border border-white/10 bg-black/25 px-4 py-2 text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-text-muted"
							>
								<span>Builder</span>
								<span class="text-accent">Disponible</span>
							</div>

							<div
								class="motion-surface relative h-72 w-72 overflow-hidden rounded-4xl border border-secondary/35 shadow-[0_0_60px_rgba(59,130,246,0.32)]"
								data-motion-active="false"
							>
								<img
									src={withBasePath("/FotoPerfil.png")}
									alt={`Foto de ${site.name}`}
									class="h-full w-full object-cover"
									onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
								/>
								<div
									class="absolute inset-0 hidden items-center justify-center bg-bg-tertiary"
									aria-hidden="true"
								>
									<svg
										class="h-20 w-20 text-text-dim"
										fill="none"
										stroke="currentColor"
										viewBox="0 0 24 24"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="1.5"
											d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
										></path>
									</svg>
								</div>
							</div>

							<div
								class="mt-4 flex items-center justify-between gap-4"
							>
								<div>
									<p
										class="text-base font-bold text-text-primary"
									>
										Rubén<span class="text-accent">PG</span>
									</p>
									<p
										class="mt-1 text-[0.68rem] uppercase tracking-[0.24em] text-text-muted"
									>
										Full stack + automatizacion
									</p>
								</div>
								<div
									class="rounded-full border border-secondary/20 bg-secondary/10 px-3 py-1.5 text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-secondary"
								>
									iCreate Group
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div
				class="hidden lg:flex lg:flex-row lg:items-center lg:gap-20 lg:min-h-screen"
			>
				<div class="flex-1 text-center lg:text-left animate-fade-in">
					<div
						class="motion-chip inline-flex items-center gap-2 bg-secondary/10 border border-secondary/25 rounded-full px-4 py-1.5 mb-6"
						data-motion-active="false"
					>
						<span
							class="w-2 h-2 bg-accent rounded-full animate-pulse"
						></span>
						<span
							class="text-accent font-semibold text-xs uppercase tracking-widest"
							>Disponible para proyectos</span
						>
					</div>

					<h1
						class="text-5xl sm:text-6xl lg:text-7xl font-black text-secondary leading-[1.05] mb-5 tracking-tight"
					>
						<span class="block">Full Stack</span>
						<span
							class="block text-transparent bg-clip-text bg-linear-to-r from-secondary via-secondary-hover to-secondary/80"
							>Developer</span
						>
						<span
							class="block text-3xl sm:text-4xl lg:text-5xl font-bold text-secondary/85 mt-2"
							>& CTO de iCreate Group</span
						>
					</h1>

					<p
						class="text-lg sm:text-xl text-text-secondary max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed"
					>
						Construyo productos que <strong
							class="text-text-primary">escalan</strong
						>. CRM a medida, automatizaciones inteligentes con n8n,
						apps desktop y webs de alto rendimiento.
					</p>

					<div
						class="flex flex-wrap gap-6 justify-center lg:justify-start mb-8"
					>
						{
							[
								{
									value: "3+",
									label: "Productos en producción",
								},
								{ value: "100%", label: "Ownership técnico" },
								{
									value: "n8n",
									label: "Automatización avanzada",
								},
							].map((stat) => (
								<div class="text-center lg:text-left">
									<div class="text-2xl font-black text-accent">
										{stat.value}
									</div>
									<div class="text-xs text-text-muted uppercase tracking-wide">
										{stat.label}
									</div>
								</div>
							))
						}
					</div>

					<div
						class="flex flex-col sm:flex-row items-center gap-4 justify-center lg:justify-start"
					>
						<Button
							href={withBasePath("/proyectos")}
							variant="primary"
							size="lg"
						>
							Ver proyectos
							<svg
								class="w-5 h-5"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
							</svg>
						</Button>
						<Button
							href={withBasePath("/contacto")}
							variant="outline"
							size="lg"
						>
							Hablemos
							<svg
								class="w-5 h-5"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
								></path>
							</svg>
						</Button>
					</div>
				</div>

				<div class="shrink-0 animate-slide-up relative">
					<div
						class="absolute -inset-4 rounded-full bg-linear-to-br from-secondary/30 via-accent/10 to-secondary/20 blur-2xl opacity-60"
					>
					</div>
					<div
						class="motion-surface w-52 h-52 sm:w-60 sm:h-60 lg:w-72 lg:h-72 rounded-full overflow-hidden border-2 border-secondary/40 shadow-[0_0_60px_rgba(59,130,246,0.32)] relative"
						data-motion-active="false"
					>
						<img
							src={withBasePath("/FotoPerfil.png")}
							alt={`Foto de ${site.name}`}
							class="w-full h-full object-cover"
							onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
						/>
						<div
							class="absolute inset-0 bg-bg-tertiary items-center justify-center hidden"
							aria-hidden="true"
						>
							<svg
								class="w-20 h-20 text-text-dim"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="1.5"
									d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
								></path>
							</svg>
						</div>
					</div>
					<div
						class="absolute -bottom-4 left-1/2 -translate-x-1/2 bg-bg-deep border border-ui-border rounded-full px-4 py-1.5 whitespace-nowrap"
					>
						<span class="text-sm font-semibold text-text-primary"
							>Rubén<span class="text-accent">PG</span></span
						>
					</div>
				</div>
			</div>
		</Container>

		<!-- Scroll indicator -->
		<div
			class="absolute bottom-10 left-1/2 hidden -translate-x-1/2 animate-bounce opacity-50 lg:block"
		>
			<svg
				class="w-6 h-6 text-text-muted"
				fill="none"
				stroke="currentColor"
				viewBox="0 0 24 24"
			>
				<path
					stroke-linecap="round"
					stroke-linejoin="round"
					stroke-width="2"
					d="M19 9l-7 7-7-7"></path>
			</svg>
		</div>
	</section>

	<div class="relative z-20 bg-bg-primary">
		<!-- ═══ VALUE PROPOSITION BAND ═══ -->
		<section
			class="py-12 border-y border-ui-border/50 bg-linear-to-b from-bg-secondary/35 to-bg-primary"
		>
			<Container size="xl">
				<ValuePropsBand client:visible items={valueProps} />
			</Container>
		</section>

		<!-- ═══ FEATURED PROJECTS ═══ -->
		<section class="py-20 sm:py-28 scroll-mt-24" id="proyectos-destacados">
			<Container size="xl">
				<SectionTitle
					title="Proyectos destacados"
					subtitle="Productos reales en producción — desde CRMs propios hasta e-commerces headless y plataformas de automatización."
				/>

				<div
					class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger-children"
				>
					{
						featuredProjects.map((project) => (
							<ProjectCard project={project} />
						))
					}
				</div>

				<div class="text-center mt-12">
					<Button
						href={withBasePath("/proyectos")}
						variant="ghost"
						size="md"
					>
						Ver todos los proyectos
						<svg
							class="w-4 h-4"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
						</svg>
					</Button>
				</div>
			</Container>
		</section>

		<!-- ═══ SKILLS ═══ -->
		<section
			class="py-20 sm:py-28 bg-bg-secondary/30 border-t border-ui-border/40"
			id="habilidades"
		>
			<Container size="xl">
				<SectionTitle
					title="Stack técnico"
					subtitle="Herramientas que domino y que uso en proyectos reales — no tutoriales, producción."
				/>

				<div
					class="space-y-3 lg:hidden"
					data-exclusive-accordion
					data-accordion-group="home-skills"
				>
					{
						skillCategories.map((category, index) => (
							<div
								class="site-accordion-item motion-surface overflow-hidden rounded-[1.6rem] border border-ui-border bg-bg-secondary/85"
								data-accordion-item
								data-default-open={
									index === 0 ? "true" : undefined
								}
								data-motion-active="false"
							>
								<button
									type="button"
									class="site-accordion-trigger flex w-full items-center gap-4 px-5 py-5 text-left"
									data-accordion-trigger
									aria-expanded="false"
									aria-controls={`skill-panel-${index}`}
								>
									<span
										class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-white/8 bg-black/20 text-3xl [&>svg]:block [&>svg]:h-full [&>svg]:w-full"
										set:html={category.icon}
									/>
									<span class="min-w-0 flex-1">
										<span class="site-accordion-heading block text-base font-bold text-text-primary">
											{category.title}
										</span>
										<span class="mt-1 block text-xs uppercase tracking-[0.22em] text-text-muted">
											{category.skills.length} tecnologías
											reales
										</span>
									</span>
									<svg
										class="site-accordion-chevron h-5 w-5 text-text-muted"
										xmlns="http://www.w3.org/2000/svg"
										viewBox="0 0 48 48"
										fill="none"
										aria-hidden="true"
									>
										<path
											stroke="currentColor"
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="4"
											d="M36 18L24 30L12 18"
										/>
									</svg>
								</button>
								<div
									class="site-accordion-panel px-5"
									data-accordion-panel
									id={`skill-panel-${index}`}
									aria-hidden="true"
								>
									<div class="border-t border-ui-border/60 pb-5 pt-4">
										<p class="mb-3 text-[0.68rem] font-semibold uppercase tracking-[0.24em] text-text-muted">
											Stack usado en producción
										</p>
										<div class="flex flex-wrap gap-1.5">
											{category.skills.map((skill) => (
												<TechBadge
													label={skill.name}
													variant="neutral"
													size="sm"
												/>
											))}
										</div>
									</div>
								</div>
							</div>
						))
					}
				</div>

				<div
					class="hidden grid-cols-1 gap-6 stagger-children sm:grid-cols-2 lg:grid lg:grid-cols-4"
				>
					{
						skillCategories.map((category) => (
							<div
								class="motion-surface bg-bg-secondary border border-ui-border rounded-2xl p-6 hover:border-secondary/40 hover:shadow-[0_0_24px_rgba(59,130,246,0.10)] transition-all duration-300 group"
								data-motion-active="false"
							>
								<div class="flex items-center gap-3 mb-5">
									<span
										class="text-3xl inline-block h-[1em] w-[1em] [&>svg]:block [&>svg]:h-full [&>svg]:w-full group-hover:scale-110 transition-transform duration-300"
										set:html={category.icon}
									/>
									<h3 class="text-base font-bold text-text-primary">
										{category.title}
									</h3>
								</div>
								<div class="flex flex-wrap gap-1.5">
									{category.skills.map((skill) => (
										<TechBadge
											label={skill.name}
											variant="neutral"
											size="sm"
										/>
									))}
								</div>
							</div>
						))
					}
				</div>
			</Container>
		</section>

		<!-- ═══ CTA STRIP ═══ -->
		<section class="py-20 sm:py-28">
			<Container size="md">
				<div
