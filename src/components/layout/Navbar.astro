---
/* ── Navbar Component ── */
import Container from "../ui/Container.astro";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const currentPath = Astro.url.pathname;
const isEn = currentPath.startsWith("/en");

const navLinks = isEn
    ? [
          { label: "Home", href: "/en" },
          { label: "Projects", href: "/en/proyectos" },
          { label: "About", href: "/en/sobre-mi" },
          { label: "Contact", href: "/en/contacto" },
      ]
    : [
          { label: "Inicio", href: "/" },
          { label: "Proyectos", href: "/proyectos" },
          { label: "Sobre mí", href: "/sobre-mi" },
          { label: "Contacto", href: "/contacto" },
      ];

const alternativePath = isEn
    ? currentPath.replace(/^\/en/, "") || "/"
    : currentPath === "/"
      ? "/en"
      : `/en${currentPath}`;
---

<nav
    class="fixed top-0 left-0 right-0 z-50 bg-bg-deep/80 backdrop-blur-md border-b border-ui-border/50"
    id="main-nav"
    aria-label={isEn ? "Main navigation" : "Navegación principal"}
>
    <Container size="xl">
        <div class="relative flex items-center justify-between h-16">
            <!-- Logo -->
            <div class="flex-1 flex justify-start">
                <a
                    href={isEn ? "/en" : "/"}
                    class="flex items-center gap-2.5 text-lg font-bold text-text-primary hover:text-secondary transition-colors duration-200 no-underline group"
                    aria-label={isEn ? "Go to home" : "Ir al inicio"}
                >
                    <img
                        src="/favicon.png"
                        alt="Logo"
                        class="w-10 h-10 rounded-md group-hover:scale-110 transition-transform duration-200"
                    />
                    <span class="tracking-tight">
                        Rubén<span class="text-accent">PG</span>
                    </span>
                </a>
            </div>

            <!-- Desktop links (Centered) -->
            <div
                class="hidden md:flex items-center gap-1 absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2"
                id="desktop-nav"
            >
                {
                    navLinks.map((link) => {
                        const isActive =
                            currentPath === link.href ||
                            (link.href !== "/" &&
                                link.href !== "/en" &&
                                currentPath.startsWith(link.href));
                        return (
                            <a
                                href={link.href}
                                class:list={[
                                    "px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 no-underline",
                                    isActive
                                        ? "text-secondary bg-secondary/15 ring-1 ring-secondary/30"
                                        : "text-text-secondary hover:text-secondary hover:bg-ui-surface",
                                ]}
                                aria-current={isActive ? "page" : undefined}
                            >
                                {link.label}
                            </a>
                        );
                    })
                }
            </div>

            <!-- Language selector + Mobile Menu Button (Right) -->
            <div class="flex-1 flex justify-end items-center gap-2">
                <div class="hidden md:block">
                    <LanguageSwitcher
                        isEn={isEn}
                        alternativePath={alternativePath}
                    />
                </div>

                <!-- Mobile menu button -->
                <button
                    class="md:hidden p-2 text-text-secondary hover:text-secondary transition-colors cursor-pointer"
                    id="mobile-menu-btn"
                    aria-label="Toggle menu"
                    aria-expanded="false"
                    aria-controls="mobile-menu"
                    type="button"
                >
                    <svg
                        class="w-6 h-6"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        id="menu-icon"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                    <svg
                        class="w-6 h-6 hidden"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        id="close-icon"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Mobile menu -->
        <div
            class="md:hidden overflow-hidden transition-[max-height,opacity] duration-300 max-h-0 opacity-0 bg-bg-deep border-b border-ui-border absolute left-0 right-0 top-16"
            id="mobile-menu"
        >
            <div class="max-h-[calc(100dvh-4rem)] overflow-y-auto overscroll-contain px-4 pb-6 pt-4 flex flex-col gap-2">
                {
                    navLinks.map((link) => {
                        const isActive =
                            currentPath === link.href ||
                            (link.href !== "/" &&
                                link.href !== "/en" &&
                                currentPath.startsWith(link.href));
                        return (
                            <a
                                href={link.href}
                                class:list={[
                                    "px-4 py-3 rounded-lg text-base font-medium transition-all duration-200 no-underline",
                                    isActive
                                        ? "text-secondary bg-secondary/15 ring-1 ring-secondary/30"
                                        : "text-text-secondary hover:text-secondary hover:bg-ui-surface",
                                ]}
                                aria-current={isActive ? "page" : undefined}
                            >
                                {link.label}
                            </a>
                        );
                    })
                }

                <div class="mt-4 pt-4 border-t border-ui-border">
                    <LanguageSwitcher
                        isEn={isEn}
                        alternativePath={alternativePath}
                        mobile={true}
                    />
                </div>
            </div>
        </div>
    </Container>
</nav>

<script>
    function initNavbarMenu() {
        const nav = document.getElementById("main-nav");
        if (!(nav instanceof HTMLElement) || nav.dataset.menuReady === "true") {
            return;
        }

        const btn = nav.querySelector("#mobile-menu-btn");
        const menu = nav.querySelector("#mobile-menu");
        const menuIcon = nav.querySelector("#menu-icon");
        const closeIcon = nav.querySelector("#close-icon");

        if (
            !(btn instanceof HTMLButtonElement) ||
            !(menu instanceof HTMLElement) ||
            !(menuIcon instanceof SVGElement) ||
            !(closeIcon instanceof SVGElement)
        ) {
            return;
        }

        const openMenu = () => {
            btn.setAttribute("aria-expanded", "true");
            menu.style.maxHeight = "calc(100dvh - 4rem)";
            menu.style.opacity = "1";
            menuIcon.classList.add("hidden");
            closeIcon.classList.remove("hidden");
        };

        const closeMenu = () => {
            btn.setAttribute("aria-expanded", "false");
            menu.style.maxHeight = "0";
            menu.style.opacity = "0";
            menuIcon.classList.remove("hidden");
            closeIcon.classList.add("hidden");
        };

        btn.addEventListener("click", () => {
            const isOpen = btn.getAttribute("aria-expanded") === "true";

            if (isOpen) {
                closeMenu();
            } else {
                openMenu();
            }
        });

        window.addEventListener("resize", () => {
            if (btn.getAttribute("aria-expanded") === "true") {
                openMenu();
            }
        });

        menu.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => {
                closeMenu();
            });
        });

        nav.dataset.menuReady = "true";
        closeMenu();
    }

    document.addEventListener("DOMContentLoaded", initNavbarMenu);
    document.addEventListener("astro:page-load", initNavbarMenu);
</script>
