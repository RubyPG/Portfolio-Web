---
/* ── Footer Component ── */
import Container from "../ui/Container.astro";
import GitHubMark from "../icons/GitHubMark.astro";
import { site } from "../../data/site";

const navLinks = [
    { label: "Inicio", href: "/" },
    { label: "Proyectos", href: "/proyectos" },
    { label: "Sobre mí", href: "/sobre-mi" },
    { label: "Contacto", href: "/contacto" },
];
---

<footer class="bg-bg-deep border-t border-ui-border" id="site-footer">
    <Container size="xl">
        <div class="py-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
            <!-- Brand -->
            <div>
                <a
                    href="/"
                    class="flex items-center gap-2.5 text-lg font-bold text-text-primary hover:text-secondary transition-colors no-underline group"
                >
                    <img
                        src="/favicon.png"
                        alt="Logo"
                        class="w-8 h-8 rounded-md group-hover:scale-110 transition-transform duration-200"
                    />
                    <span class="tracking-tight">
                        Rubén<span class="text-accent">PG</span>
                    </span>
                </a>
                <p class="mt-3 text-text-muted text-sm leading-relaxed">
                    {site.role} especializado en automatización, desarrollo web y
                    aplicaciones desktop.
                </p>
            </div>

            <!-- Links rápidos -->
            <div>
                <h3
                    class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4"
                >
                    Navegación
                </h3>
                <ul class="space-y-2">
                    {
                        navLinks.map((link) => (
                            <li>
                                <a
                                    href={link.href}
                                    class="text-sm text-text-muted hover:text-secondary transition-colors no-underline"
                                >
                                    {link.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Social -->
            <div>
                <h3
                    class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4"
                >
                    Social
                </h3>
                <ul class="space-y-2">
                    {
                        site.socials.map((social) => (
                            <li>
                                <a
                                    href={social.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-sm text-text-muted hover:text-secondary transition-colors no-underline inline-flex items-center gap-2"
                                    aria-label={`Visitar ${social.label}`}
                                >
                                    {social.icon === "github" && (
                                        <GitHubMark class="w-4 h-4" />
                                    )}
                                    {social.icon === "linkedin" && (
                                        <svg
                                            class="w-4 h-4"
                                            xmlns="http://www.w3.org/2000/svg"
                                            viewBox="0 0 256 256"
                                            fill="none"
                                        >
                                            <rect width="256" height="256" fill="#fff" rx="60" />
                                            <rect width="256" height="256" fill="#0A66C2" rx="60" />
                                            <path fill="#fff" d="M184.715 217.685h29.27a4 4 0 0 0 4-3.999l.015-61.842c0-32.323-6.965-57.168-44.738-57.168c-14.359-.534-27.9 6.868-35.207 19.228a.32.32 0 0 1-.595-.161V101.66a4 4 0 0 0-4-4h-27.777a4 4 0 0 0-4 4v112.02a4 4 0 0 0 4 4h29.268a4 4 0 0 0 4-4v-55.373c0-15.657 2.97-30.82 22.381-30.82c19.135 0 19.383 17.916 19.383 31.834v54.364a4 4 0 0 0 4 4M38 59.628c0 11.864 9.767 21.626 21.632 21.626c11.862-.001 21.623-9.769 21.623-21.631C81.253 47.761 71.491 38 59.628 38C47.762 38 38 47.763 38 59.627m6.959 158.058h29.307a4 4 0 0 0 4-4V101.66a4 4 0 0 0-4-4H44.959a4 4 0 0 0-4 4v112.025a4 4 0 0 0 4 4" />
                                        </svg>
                                    )}
                                    {social.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </div>

            <!-- Contacto -->
            <div>
                <h3
                    class="text-sm font-semibold text-text-primary uppercase tracking-wider mb-4"
                >
                    Contacto
                </h3>
                <ul class="space-y-2">
                    <li>
                        <a
                            href={`mailto:${site.contact.email}`}
                            class="text-sm text-text-muted hover:text-secondary transition-colors no-underline inline-flex items-center gap-2"
                            aria-label="Enviar email"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                ></path>
                            </svg>
                            {site.contact.email}
                        </a>
                    </li>
                    <li>
                        <a
                            href={`tel:${site.contact.phone}`}
                            class="text-sm text-text-muted hover:text-secondary transition-colors no-underline inline-flex items-center gap-2"
                            aria-label="Llamar por teléfono"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                ></path>
                            </svg>
                            +34 618 856 782
                        </a>
                    </li>
                    <li>
                        <a
                            href={`https://wa.me/${site.contact.whatsapp}`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="text-sm text-text-muted hover:text-secondary transition-colors no-underline inline-flex items-center gap-2"
                            aria-label="Contactar por WhatsApp"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                                ></path>
                            </svg>
                            WhatsApp
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Copyright -->
        <div
            class="border-t border-ui-border py-6 flex flex-col sm:flex-row items-center justify-between gap-4"
        >
            <p class="text-sm text-text-dim">
                {site.footer.copyright}
            </p>

            <!-- Back to top -->
            <button
                id="back-to-top"
                class="text-sm text-text-muted hover:text-secondary transition-colors inline-flex items-center gap-1.5 cursor-pointer"
                aria-label="Volver arriba"
                type="button"
            >
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
                </svg>
                Volver arriba
            </button>
        </div>
    </Container>
</footer>

<script>
    const backToTop = document.getElementById("back-to-top");
    backToTop?.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
    });
</script>
