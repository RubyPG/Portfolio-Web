<script>
    function setAccordionState(item, shouldOpen, animate = true) {
        if (!(item instanceof HTMLElement)) return;

        const trigger = item.querySelector("[data-accordion-trigger]");
        const panel = item.querySelector("[data-accordion-panel]");

        if (!(trigger instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) {
            return;
        }

        item.dataset.open = String(shouldOpen);
        trigger.dataset.open = String(shouldOpen);
        trigger.setAttribute("aria-expanded", String(shouldOpen));
        panel.dataset.open = String(shouldOpen);
        panel.setAttribute("aria-hidden", String(!shouldOpen));

        const nextHeight = shouldOpen ? `${panel.scrollHeight}px` : "0px";

        if (!animate) {
            panel.style.maxHeight = nextHeight;
            return;
        }

        if (shouldOpen) {
            panel.style.maxHeight = "0px";
            requestAnimationFrame(() => {
                panel.style.maxHeight = `${panel.scrollHeight}px`;
            });
            return;
        }

        panel.style.maxHeight = `${panel.scrollHeight}px`;
        requestAnimationFrame(() => {
            panel.style.maxHeight = "0px";
        });
    }

    function syncAccordionHeights() {
        document
            .querySelectorAll("[data-accordion-item][data-open='true'] [data-accordion-panel]")
            .forEach((panel) => {
                if (panel instanceof HTMLElement) {
                    panel.style.maxHeight = `${panel.scrollHeight}px`;
                }
            });
    }

    function initExclusiveAccordions() {
        document.querySelectorAll("[data-exclusive-accordion]").forEach((group) => {
            if (!(group instanceof HTMLElement)) return;

            const items = Array.from(group.querySelectorAll("[data-accordion-item]"));
            if (items.length === 0) return;

            items.forEach((item, index) => {
                if (!(item instanceof HTMLElement)) return;

                const trigger = item.querySelector("[data-accordion-trigger]");
                if (!(trigger instanceof HTMLButtonElement)) return;

                if (trigger.dataset.bound !== "true") {
                    trigger.dataset.bound = "true";
                    trigger.addEventListener("click", () => {
                        const isOpen = item.dataset.open === "true";

                        items.forEach((otherItem) => {
                            if (otherItem instanceof HTMLElement) {
                                setAccordionState(otherItem, false);
                            }
                        });

                        if (!isOpen) {
                            setAccordionState(item, true);
                        }
                    });
                }

                const shouldStartOpen =
                    item.dataset.open === "true" ||
                    (item.dataset.defaultOpen === "true" && index === 0);

                setAccordionState(item, shouldStartOpen, false);
            });
        });

        syncAccordionHeights();
    }

    function initFooterInteractions() {
        const backToTop = document.getElementById("back-to-top");

        if (backToTop instanceof HTMLButtonElement && backToTop.dataset.bound !== "true") {
            backToTop.dataset.bound = "true";
            backToTop.addEventListener("click", () => {
                window.scrollTo({ top: 0, behavior: "smooth" });
            });
        }

        initExclusiveAccordions();
    }

    document.addEventListener("DOMContentLoaded", initFooterInteractions);
    document.addEventListener("astro:page-load", initFooterInteractions);

    if (document.documentElement.dataset.siteFooterResizeBound !== "true") {
        window.addEventListener("resize", syncAccordionHeights);
        document.documentElement.dataset.siteFooterResizeBound = "true";
    }
</script>
