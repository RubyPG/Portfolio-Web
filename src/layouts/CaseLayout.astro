---
/* ── CaseLayout — layout for case study pages ── */
import BaseLayout from "./BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";
import TechBadge from "../components/ui/TechBadge.astro";
import GitHubMark from "../components/icons/GitHubMark.astro";
import CaseGallery from "../components/projects/CaseGallery";
import { withBasePath } from "../utils/base-path";

interface Props {
    frontmatter: {
        caseSlug: string;
        title: string;
        summary: string;
        type: string;
        tags: string[];
        stack: string[];
        role: string;
        status: string;
        year: string;
        cover?: string;
        coverIframe?: string;
        links?: {
            repo?: string | null;
            demo?: string | null;
            docs?: string | null;
        };
        gallery?: Array<{
            image: string;
            alt: string;
            title: string;
            description: string;
            label?: string;
        }>;
    };
}

const { frontmatter } = Astro.props;
const coverSrc = frontmatter.cover ? withBasePath(frontmatter.cover) : undefined;
const galleryItems = frontmatter.gallery?.map((item) => ({
    ...item,
    image: withBasePath(item.image),
}));
---

<BaseLayout title={frontmatter.title} description={frontmatter.summary}>
    <article class="py-12 sm:py-16">
        <Container size="md">
            <!-- Back link -->
            <div class="mb-8">
                <Button href="/proyectos" variant="ghost" size="sm">
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Volver a proyectos
                </Button>
            </div>

            <!-- Header -->
            <header class="mb-12">
                <div class="flex flex-wrap gap-2 mb-4">
                    <Badge variant="accent" size="sm">{frontmatter.type}</Badge>
                    {
                        frontmatter.tags.map((tag) => (
                            <Badge variant="outline" size="sm">
                                {tag}
                            </Badge>
                        ))
                    }
                </div>

                <h1
                    class="text-3xl sm:text-4xl lg:text-5xl font-bold text-text-primary mb-4"
                >
                    {frontmatter.title}
                </h1>

                <p class="text-lg text-text-secondary mb-6 leading-relaxed">
                    {frontmatter.summary}
                </p>

                <!-- Meta info -->
                <div
                    class="flex flex-wrap gap-6 text-sm text-text-muted border-t border-b border-ui-border py-4"
                >
                    <div class="flex items-center gap-2">
                        <svg
                            class="w-4 h-4 text-accent"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                            ></path>
                        </svg>
                        <span>{frontmatter.role}</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <svg
                            class="w-4 h-4 text-accent"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                            ></path>
                        </svg>
                        <span>{frontmatter.year}</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span
                            class={`w-2 h-2 rounded-full ${frontmatter.status === "En curso" ? "bg-accent animate-pulse" : "bg-state-success"}`}
                        ></span>
                        <span>{frontmatter.status}</span>
                    </div>
                </div>

                <!-- Stack -->
                <div class="mt-4 flex flex-wrap gap-1.5">
                    {
                        frontmatter.stack.map((tech) => (
                            <TechBadge label={tech} variant="neutral" size="sm" />
                        ))
                    }
                </div>

                <!-- Links -->
                {
                    frontmatter.links && (
                        <div class="mt-6 flex flex-wrap gap-3">
                            {frontmatter.links.demo && (
                                <Button
                                    href={frontmatter.links.demo}
                                    variant="primary"
                                    size="sm"
                                    external
                                >
                                    <svg
                                        class="w-4 h-4"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                                        />
                                    </svg>
                                    Ver demo
                                </Button>
                            )}
                            {frontmatter.links.repo && (
                                <Button
                                    href={frontmatter.links.repo}
                                    variant="secondary"
                                    size="sm"
                                    external
                                >
                                    <GitHubMark class="w-4 h-4" />
                                    Código fuente
                                </Button>
                            )}
                        </div>
                    )
                }
            </header>

            <!-- Cover image -->
            {
                (frontmatter.coverIframe || frontmatter.cover) && (
                    <div class="mb-12 aspect-video bg-bg-tertiary rounded-lg overflow-hidden">
                        {frontmatter.coverIframe ? (
                            <iframe
                                src={frontmatter.coverIframe}
                                title={`Portada de ${frontmatter.title}`}
                                class="h-full border-0 pointer-events-none"
                                style="width: calc(100% + 16px); margin-right: -16px;"
                                loading="lazy"
                                scrolling="no"
                            ></iframe>
                        ) : (
                            <>
                                <img
                                    src={coverSrc}
                                    alt={`Portada de ${frontmatter.title}`}
                                    class="w-full h-full object-cover"
                                    loading="lazy"
                                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                                />
                                <div
                                    class="hidden h-full w-full items-center justify-center text-text-dim text-sm"
                                    aria-hidden="true"
                                >
                                    📸 Imagen pendiente
                                </div>
                            </>
                        )}
                    </div>
                )
            }

            <!-- Markdown content -->
            <div class="prose max-w-none">
                <slot />
            </div>

            {
                galleryItems && galleryItems.length > 0 && (
                    <CaseGallery
                        client:visible
                        items={galleryItems}
                        projectTitle={frontmatter.title}
                    />
                )
            }

            <!-- Navigation -->
            <div
                class="mt-16 pt-8 border-t border-ui-border flex justify-between items-center"
            >
                <Button href="/proyectos" variant="ghost" size="md">
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    Todos los proyectos
                </Button>

                <Button href="/contacto" variant="primary" size="md">
                    Contactar
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                </Button>
            </div>
        </Container>
    </article>
</BaseLayout>
